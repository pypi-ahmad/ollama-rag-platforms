# Ollama
OLLAMA_HOST=http://127.0.0.1:11434
CHAT_MODEL=phi3.5:3.8b
EMBEDDING_MODEL=embeddinggemma:latest

# Retrieval and generation
SEED=42
CHUNK_SIZE_WORDS=170
CHUNK_OVERLAP_WORDS=35
RETRIEVAL_TOP_K=4
GENERATION_TEMPERATURE=0.1
GENERATION_MAX_TOKENS=220
GENERATION_TIMEOUT_SECONDS=15
EMBEDDING_TIMEOUT_SECONDS=90

# Paths
KNOWLEDGE_DIR=data/knowledge
EVALUATION_FILE=data/eval/questions.json
ARTIFACTS_DIR=artifacts
INDEX_DIR=artifacts/index
EVAL_DIR=artifacts/evals
REPORT_DIR=artifacts/reports
TELEMETRY_DIR=artifacts/telemetry
