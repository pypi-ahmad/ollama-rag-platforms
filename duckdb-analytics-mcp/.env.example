# Server runtime
SERVER_NAME=duckdb_analytics_mcp
LOG_LEVEL=INFO
HOST=127.0.0.1
PORT=8000
TRANSPORT=streamable-http

# Dataset catalog root (relative to project root or absolute)
DATASET_DIR=data

# Query guardrails
DEFAULT_LIMIT=25
MAX_LIMIT=200
MAX_QUERY_CHARS=4000
QUERY_TIMEOUT_SECONDS=20
MAX_SAMPLE_ROWS=25

# DuckDB runtime
DUCKDB_THREADS=4
DUCKDB_MEMORY_LIMIT=1GB

# Optional auth (enable all three together)
# STATIC_BEARER_TOKEN=replace-with-strong-token
# AUTH_ISSUER_URL=https://auth.example.com
# AUTH_RESOURCE_SERVER_URL=https://mcp.example.com
# AUTH_REQUIRED_SCOPE=analytics.read
